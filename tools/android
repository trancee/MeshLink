    adb_text(command, device_id=device_id, timeout=10)
    print_output(
        {
            "deviceId": device_id,
            "action": "swipe",
            "from": {"x": args.x1, "y": args.y1},
            "to": {"x": args.x2, "y": args.y2},
            "durationMs": args.duration,
        },
        args.json,
    )


def cmd_input_tap_element(args):
    device_id = choose_device(args.device)
    _, elements = load_ui_elements(device_id)
    matches = find_elements(elements, args.by, args.value)
    if not matches:
        raise ToolError(f'No element found for {args.by}="{args.value}"')
    best = matches[0]
    adb_text(
        ["shell", "input", "tap", str(best["center"]["x"]), str(best["center"]["y"])],
        device_id=device_id,
        timeout=10,
    )
    print_output(
        {"deviceId": device_id, "selector": {"by": args.by, "value": args.value}, "element": best},
        args.json,
    )


def cmd_wait_element(args):
    device_id = choose_device(args.device)
    deadline = time.time() + args.timeout / 1000.0
    while time.time() < deadline:
        try:
            _, elements = load_ui_elements(device_id)
        except ToolError:
            time.sleep(args.interval / 1000.0)
            continue
        matches = find_elements(elements, args.by, args.value)
        if matches:
            elapsed = int((time.time() - (deadline - args.timeout / 1000.0)) * 1000)
            print_output(
                {
                    "deviceId": device_id,
                    "selector": {"by": args.by, "value": args.value},
                    "elapsedMs": elapsed,
                    "element": matches[0],
                },
                args.json,
            )
            return
        time.sleep(args.interval / 1000.0)
    raise ToolError(f'Element {args.by}="{args.value}" did not appear within {args.timeout}ms.')


def cmd_scroll_find(args):
    device_id = choose_device(args.device)
    width, height = get_screen_size(device_id)
    center_x = round(width / 2)
    from_y = round(height * 0.75)
    to_y = round(height * 0.25)
    previous_signature = None

    for scroll_count in range(args.max_scrolls + 1):
        _, elements = load_ui_elements(device_id)
        matches = find_elements(elements, args.by, args.value)
        if matches:
            print_output(
                {
                    "deviceId": device_id,
                    "selector": {"by": args.by, "value": args.value},
                    "scrolls": scroll_count,
                    "element": matches[0],
                },
                args.json,
            )
            return

        if scroll_count == args.max_scrolls:
            break

        signature = json.dumps(elements, sort_keys=True)
        if signature == previous_signature:
            break
        previous_signature = signature

        adb_text(
            ["shell", "input", "swipe", str(center_x), str(from_y), str(center_x), str(to_y), str(args.duration)],
            device_id=device_id,
            timeout=10,
        )
        time.sleep(args.pause / 1000.0)

    raise ToolError(f'Element {args.by}="{args.value}" was not found after scrolling.')


def cmd_app_install(args):
    device_id = choose_device(args.device)
    apk_path = pathlib.Path(args.apk)
    if not apk_path.exists():
        raise ToolError(f"APK not found: {apk_path}")

    output = adb_text(["install", "-r", str(apk_path)], device_id=device_id, timeout=90)
    package_name = args.package or detect_package_from_apk(str(apk_path))
    payload = {
        "deviceId": device_id,
        "apk": str(apk_path.resolve()),
        "packageName": package_name,
        "output": output.strip(),
    }
    print_output(payload, args.json)


def cmd_app_launch(args):
    device_id = choose_device(args.device)
    if args.activity:
        output = adb_text(
            ["shell", "am", "start", "-n", f"{args.package}/{args.activity}"],
            device_id=device_id,
            timeout=20,
        )
    else:
        output = adb_text(
            ["shell", "monkey", "-p", args.package, "-c", "android.intent.category.LAUNCHER", "1"],
            device_id=device_id,
            timeout=20,
        )
    payload = {"deviceId": device_id, "packageName": args.package, "activity": args.activity, "output": output.strip()}
    print_output(payload, args.json)


def cmd_app_current(args):
    device_id = choose_device(args.device)
    payload = {"deviceId": device_id, **get_current_activity(device_id)}
    print_output(payload, args.json)


def cmd_debug_logs(args):
    device_id = choose_device(args.device)
    output = get_logs(
        device_id,
        package_name=args.package,
        level=args.level,
        lines=args.lines,
        since=args.since,
    )
    payload = {
        "deviceId": device_id,
        "packageName": args.package,
        "level": args.level,
        "lines": output.splitlines(),
        "lineCount": len(output.splitlines()) if output else 0,
    }
    if args.json:
        print_output(payload, True)
        return
    print(output or "(no log output)")


def cmd_debug_clear_logs(args):
    device_id = choose_device(args.device)
    adb_text(["logcat", "-c"], device_id=device_id, timeout=10)
    print_output({"deviceId": device_id, "cleared": True}, args.json)


def build_parser():
    parser = argparse.ArgumentParser(
        prog="tools/android",
        description="Command-first Android automation helpers for skill-based agents.",
    )
    subparsers = parser.add_subparsers(dest="group")
    subparsers.required = True

    device = subparsers.add_parser("device", help="Device and emulator commands")
    device_subparsers = device.add_subparsers(dest="action")
    device_subparsers.required = True

    device_list = device_subparsers.add_parser("list", help="List connected devices")
    add_common_json(device_list)
    device_list.set_defaults(func=cmd_device_list)

    device_info = device_subparsers.add_parser("info", help="Show device info")
    add_common_device(device_info)
    add_common_json(device_info)
    device_info.set_defaults(func=cmd_device_info)

    device_avds = device_subparsers.add_parser("avds", help="List available AVDs")
    add_common_json(device_avds)
    device_avds.set_defaults(func=cmd_device_avds)

    device_start = device_subparsers.add_parser("start-emulator", help="Start an emulator by AVD name")
    device_start.add_argument("--avd-name", required=True)
    device_start.add_argument("--timeout", type=int, default=60000, help="Boot timeout in milliseconds")
    add_common_device(device_start)
    add_common_json(device_start)
    device_start.set_defaults(func=cmd_device_start)

    screenshot = subparsers.add_parser("screenshot", help="Capture a screenshot")
    add_common_device(screenshot)
    add_common_json(screenshot)
    screenshot.add_argument("--out", help="Write the screenshot to a specific path")
    screenshot.set_defaults(func=cmd_screenshot)

    ui = subparsers.add_parser("ui", help="UI hierarchy commands")
    ui_subparsers = ui.add_subparsers(dest="action")
    ui_subparsers.required = True

    ui_dump = ui_subparsers.add_parser("dump", help="Dump the current UI tree")
    add_common_device(ui_dump)
    add_common_json(ui_dump)
    ui_dump.add_argument("--raw-xml", action="store_true", help="Also print the raw XML when not using --json")
    ui_dump.set_defaults(func=cmd_ui_dump)

    ui_find = ui_subparsers.add_parser("find", help="Find UI elements")
    add_common_device(ui_find)
    add_common_json(ui_find)
    ui_find.add_argument("--by", choices=["resource-id", "text", "content-desc"], required=True)
    ui_find.add_argument("--value", required=True)
    ui_find.set_defaults(func=cmd_ui_find)

    input_parser = subparsers.add_parser("input", help="Input commands")
    input_subparsers = input_parser.add_subparsers(dest="action")
    input_subparsers.required = True

    input_tap = input_subparsers.add_parser("tap", help="Tap at coordinates")
    add_common_device(input_tap)
    add_common_json(input_tap)
    input_tap.add_argument("--x", type=int, required=True)
    input_tap.add_argument("--y", type=int, required=True)
    input_tap.set_defaults(func=cmd_input_tap)

    input_text = input_subparsers.add_parser("text", help="Type text into the focused field")
    add_common_device(input_text)
    add_common_json(input_text)
    input_text.add_argument("--text", required=True)
    input_text.set_defaults(func=cmd_input_text)

    input_key = input_subparsers.add_parser("key", help="Send a key event")
    add_common_device(input_key)
    add_common_json(input_key)
    input_key.add_argument("--key", choices=sorted(KEYCODES.keys()))
    input_key.add_argument("--code", type=int)
    input_key.set_defaults(func=cmd_input_key)

    input_swipe = input_subparsers.add_parser("swipe", help="Perform a swipe")
    add_common_device(input_swipe)
    add_common_json(input_swipe)
    input_swipe.add_argument("--x1", type=int, required=True)
    input_swipe.add_argument("--y1", type=int, required=True)
    input_swipe.add_argument("--x2", type=int, required=True)
    input_swipe.add_argument("--y2", type=int, required=True)
    input_swipe.add_argument("--duration", type=int, default=300)
    input_swipe.set_defaults(func=cmd_input_swipe)

    input_tap_element = input_subparsers.add_parser("tap-element", help="Find and tap an element")
    add_common_device(input_tap_element)
    add_common_json(input_tap_element)
    input_tap_element.add_argument("--by", choices=["resource-id", "text", "content-desc"], required=True)
    input_tap_element.add_argument("--value", required=True)
    input_tap_element.set_defaults(func=cmd_input_tap_element)

    wait = subparsers.add_parser("wait", help="Wait for UI conditions")
    wait_subparsers = wait.add_subparsers(dest="action")
    wait_subparsers.required = True

    wait_element = wait_subparsers.add_parser("element", help="Wait for an element to appear")
    add_common_device(wait_element)
    add_common_json(wait_element)
    wait_element.add_argument("--by", choices=["resource-id", "text", "content-desc"], required=True)
    wait_element.add_argument("--value", required=True)
    wait_element.add_argument("--timeout", type=int, default=10000)
    wait_element.add_argument("--interval", type=int, default=500)
    wait_element.set_defaults(func=cmd_wait_element)

    scroll = subparsers.add_parser("scroll", help="Scrolling helpers")
    scroll_subparsers = scroll.add_subparsers(dest="action")
    scroll_subparsers.required = True

    scroll_find = scroll_subparsers.add_parser("find", help="Scroll until an element is visible")
    add_common_device(scroll_find)
    add_common_json(scroll_find)
    scroll_find.add_argument("--by", choices=["resource-id", "text", "content-desc"], required=True)
    scroll_find.add_argument("--value", required=True)
    scroll_find.add_argument("--max-scrolls", type=int, default=10)
    scroll_find.add_argument("--duration", type=int, default=500)
    scroll_find.add_argument("--pause", type=int, default=500)
    scroll_find.set_defaults(func=cmd_scroll_find)

    app = subparsers.add_parser("app", help="App management commands")
    app_subparsers = app.add_subparsers(dest="action")
    app_subparsers.required = True

    app_install = app_subparsers.add_parser("install", help="Install an APK")
    add_common_device(app_install)
    add_common_json(app_install)
    app_install.add_argument("--apk", required=True)
    app_install.add_argument("--package", help="Explicit package name to associate with the APK")
    app_install.set_defaults(func=cmd_app_install)

    app_launch = app_subparsers.add_parser("launch", help="Launch an app")
    add_common_device(app_launch)
    add_common_json(app_launch)
    app_launch.add_argument("--package", required=True)
    app_launch.add_argument("--activity")
    app_launch.set_defaults(func=cmd_app_launch)

    app_current = app_subparsers.add_parser("current", help="Get the foreground activity")
    add_common_device(app_current)
    add_common_json(app_current)
    app_current.set_defaults(func=cmd_app_current)

    debug = subparsers.add_parser("debug", help="Debugging helpers")
    debug_subparsers = debug.add_subparsers(dest="action")
    debug_subparsers.required = True

    debug_logs = debug_subparsers.add_parser("logs", help="Read logcat output")
    add_common_device(debug_logs)
    add_common_json(debug_logs)
    debug_logs.add_argument("--package")
    debug_logs.add_argument("--level", choices=["V", "D", "I", "W", "E", "F"])
    debug_logs.add_argument("--lines", type=int, default=200)
    debug_logs.add_argument("--since")
    debug_logs.set_defaults(func=cmd_debug_logs)

    debug_clear = debug_subparsers.add_parser("clear-logs", help="Clear logcat")
    add_common_device(debug_clear)
    add_common_json(debug_clear)
    debug_clear.set_defaults(func=cmd_debug_clear_logs)

    return parser


def main():
    parser = build_parser()
    args = parser.parse_args()
    try:
        args.func(args)
    except ToolError as exc:
        if getattr(args, "json", False):
            print(json.dumps({"error": str(exc)}, indent=2), file=sys.stderr)
        else:
            print(f"Error: {exc}", file=sys.stderr)
        return 1
    return 0


if __name__ == "__main__":
    sys.exit(main())
