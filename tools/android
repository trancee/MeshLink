import xml.etree.ElementTree as ET


KEYCODES = {
    "back": 4,
    "home": 3,
    "enter": 66,
    "tab": 61,
    "delete": 67,
    "menu": 82,
    "recent_apps": 187,
    "volume_up": 24,
    "volume_down": 25,
    "power": 26,
    "search": 84,
    "dpad_up": 19,
    "dpad_down": 20,
    "dpad_left": 21,
    "dpad_right": 22,
    "dpad_center": 23,
}


UI_DUMP_RETRIES = 3


class ToolError(RuntimeError):
    pass


def discover_sdk_roots():
    roots = []
    for env_name in ("ANDROID_HOME", "ANDROID_SDK_ROOT"):
        value = os.environ.get(env_name)
        if value:
            roots.append(value)

    home = pathlib.Path.home()
    roots.append(str(home / "Library" / "Android" / "sdk"))
    roots.append(str(home / "Android" / "Sdk"))

    unique = []
    for root in roots:
        if root and root not in unique:
            unique.append(root)
    return unique


def discover_binary(relative_path, fallback_name):
    for sdk_root in discover_sdk_roots():
        candidate = pathlib.Path(sdk_root) / relative_path
        if candidate.exists():
            return str(candidate)

    on_path = shutil.which(fallback_name)
    return on_path or fallback_name


ADB_PATH = discover_binary("platform-tools/adb", "adb")
EMULATOR_PATH = discover_binary("emulator/emulator", "emulator")


def discover_build_tool(name):
    for sdk_root in discover_sdk_roots():
        build_tools = pathlib.Path(sdk_root) / "build-tools"
        if build_tools.exists():
            versions = sorted(build_tools.iterdir(), reverse=True)
            for version_dir in versions:
                candidate = version_dir / name
                if candidate.exists():
                    return str(candidate)

        cmdline_candidates = [
            pathlib.Path(sdk_root) / "cmdline-tools" / "latest" / "bin" / name,
            pathlib.Path(sdk_root) / "cmdline-tools" / "bin" / name,
            pathlib.Path(sdk_root) / "tools" / "bin" / name,
        ]
        for candidate in cmdline_candidates:
            if candidate.exists():
                return str(candidate)

    return shutil.which(name)


def run_command(command, *, text=True, check=True, timeout=10):
    try:
        return subprocess.run(
            command,
            check=check,
            capture_output=True,
            text=text,
            timeout=timeout,
        )
    except subprocess.CalledProcessError as exc:
        stderr = exc.stderr.decode() if isinstance(exc.stderr, bytes) else exc.stderr
        stdout = exc.stdout.decode() if isinstance(exc.stdout, bytes) else exc.stdout
        output = "\n".join(part for part in [stdout, stderr] if part).strip()
        raise ToolError(output or f"Command failed: {' '.join(command)}") from exc
    except FileNotFoundError as exc:
        raise ToolError(f"Command not found: {command[0]}") from exc
    except subprocess.TimeoutExpired as exc:
        raise ToolError(f"Command timed out after {timeout}s: {' '.join(command)}") from exc


def adb_base(device_id=None):
    base = [ADB_PATH]
    if device_id:
        base.extend(["-s", device_id])
    return base


def adb_text(args, *, device_id=None, check=True, timeout=10):
    result = run_command(adb_base(device_id) + args, text=True, check=check, timeout=timeout)
    return result.stdout


def adb_result(args, *, device_id=None, check=True, timeout=10):
    return run_command(adb_base(device_id) + args, text=True, check=check, timeout=timeout)


def adb_bytes(args, *, device_id=None, timeout=10):
    result = run_command(adb_base(device_id) + args, text=False, check=True, timeout=timeout)
    return result.stdout


def command_output(result):
    return "\n".join(part for part in [result.stdout, result.stderr] if part).strip()


def parse_devices(output):
    devices = []
    for raw_line in output.splitlines():
        line = raw_line.strip()
        if not line or line.startswith("List of devices"):
            continue
        parts = re.split(r"\s+", line)
        if len(parts) < 2:
            continue
        device_id = parts[0]
        state = parts[1]
        model_match = re.search(r"model:(\S+)", line)
        devices.append(
            {
                "id": device_id,
                "state": state,
                "model": model_match.group(1) if model_match else None,
                "raw": line,
            }
        )
    return devices


def get_devices():
    return parse_devices(adb_text(["devices", "-l"], timeout=10))


def choose_device(explicit_device=None):
    if explicit_device:
        return explicit_device

    env_device = os.environ.get("ANDROID_SERIAL")
    if env_device:
        return env_device

    ready = [device for device in get_devices() if device["state"] == "device"]
    if not ready:
        raise ToolError("No ready Android devices detected. Connect a device or start an emulator.")
    if len(ready) > 1:
        device_lines = "\n".join(f"- {device['id']}" for device in ready)
        raise ToolError(f"Multiple devices detected. Re-run with --device.\n{device_lines}")
    return ready[0]["id"]


def parse_bounds(bounds_str):
    match = re.fullmatch(r"\[(\d+),(\d+)\]\[(\d+),(\d+)\]", bounds_str or "")
    if not match:
        return None

    left, top, right, bottom = [int(group) for group in match.groups()]
    if right <= left or bottom <= top:
        return None
    return {
        "x": left,
        "y": top,
        "width": right - left,
        "height": bottom - top,
    }


def center_from_bounds(bounds):
    return {
        "x": round(bounds["x"] + bounds["width"] / 2),
        "y": round(bounds["y"] + bounds["height"] / 2),
    }


def get_ui_xml(device_id):
    attempts = []
    for attempt in range(UI_DUMP_RETRIES):
        primary = adb_result(["shell", "uiautomator", "dump", "/dev/tty"], device_id=device_id, check=False, timeout=20)
        primary_output = command_output(primary)
        xml = extract_xml(primary_output)
        if xml:
            return xml

        fallback_dump = adb_result(
            ["shell", "uiautomator", "dump", "/sdcard/window_dump.xml"],
            device_id=device_id,
            check=False,
            timeout=20,
        )
        fallback_cat = adb_result(
            ["shell", "cat", "/sdcard/window_dump.xml"],
            device_id=device_id,
            check=False,
            timeout=20,
        )
        fallback_output = "\n".join(
            part for part in [command_output(fallback_dump), command_output(fallback_cat)] if part
        )
        xml = extract_xml(fallback_output)
        if xml:
            return xml

        attempts.append(
            {
                "primary": primary_output,
                "fallback": fallback_output,
            }
        )
        if attempt + 1 < UI_DUMP_RETRIES:
            time.sleep(0.5)

    last_attempt = attempts[-1] if attempts else {}
    detail = last_attempt.get("primary") or last_attempt.get("fallback") or "uiautomator dump returned no XML"
    raise ToolError(f"Unable to read UI hierarchy from the device. Last output: {detail}")


def extract_xml(output):
    xml_start = output.find("<?xml")
    hierarchy_start = output.find("<hierarchy")
    start = xml_start if xml_start != -1 else hierarchy_start
    if start == -1:
        return None
    return output[start:].strip()


def parse_ui_xml(xml_text):
    try:
        root = ET.fromstring(xml_text)
    except ET.ParseError as exc:
        raise ToolError(f"Failed to parse UI XML: {exc}") from exc

    elements = []
    for node in root.iter("node"):
        resource_id = node.attrib.get("resource-id", "")
        text = node.attrib.get("text", "")
        content_desc = node.attrib.get("content-desc", "")
        clickable = node.attrib.get("clickable") == "true"
        bounds = parse_bounds(node.attrib.get("bounds", ""))
        if not bounds:
            continue
        if not (resource_id or text or content_desc or clickable):
            continue

        elements.append(
            {
                "index": int(node.attrib.get("index", "0") or "0"),
                "resourceId": resource_id,
                "text": text,
                "contentDesc": content_desc,
                "className": node.attrib.get("class", ""),
                "bounds": bounds,
                "center": center_from_bounds(bounds),
                "clickable": clickable,
                "enabled": node.attrib.get("enabled") == "true",
                "focused": node.attrib.get("focused") == "true",
                "checked": node.attrib.get("checked") == "true",
                "scrollable": node.attrib.get("scrollable") == "true",
            }
        )
    return elements


def match_element(element, by, value):
    lowered = value.lower()
    if by == "resource-id":
        resource_id = element["resourceId"]
        return resource_id == value or resource_id.endswith(f":id/{value}") or resource_id.endswith(f"/{value}")
    if by == "text":
        return lowered in element["text"].lower()
    if by == "content-desc":
        return lowered in element["contentDesc"].lower()
    raise ToolError(f"Unsupported selector: {by}")


def element_score(element, by, value):
    score = 0
    candidate = {
        "resource-id": element["resourceId"],
        "text": element["text"],
        "content-desc": element["contentDesc"],
    }[by]

    if candidate == value:
        score += 10
    elif candidate.endswith(f":id/{value}") or candidate.endswith(f"/{value}"):
        score += 8
    elif value.lower() in candidate.lower():
        score += 5

    if element["clickable"]:
        score += 3
    if element["enabled"]:
        score += 2
    return score


def find_elements(elements, by, value):
    matches = [element for element in elements if match_element(element, by, value)]
    matches.sort(key=lambda item: element_score(item, by, value), reverse=True)
    return matches


def escape_input_text(text):
    escaped = []
    replacements = {
        " ": "%s",
        "\\": "\\\\",
        "'": "\\'",
        '"': '\\"',
        "`": "\\`",
        "$": "\\$",
        "&": "\\&",
        "|": "\\|",
        ";": "\\;",
        "(": "\\(",
        ")": "\\)",
        "<": "\\<",
        ">": "\\>",
        "!": "\\!",
    }
    for char in text:
        escaped.append(replacements.get(char, char))
    return "".join(escaped)


def get_screen_size(device_id):
    output = adb_text(["shell", "wm", "size"], device_id=device_id, timeout=10)
    match = re.search(r"(\d+)x(\d+)", output)
    if not match:
        raise ToolError(f"Could not parse screen size from: {output.strip()}")
    return int(match.group(1)), int(match.group(2))


def get_current_activity(device_id):
    output = adb_text(["shell", "dumpsys", "activity", "activities"], device_id=device_id, timeout=15)
    patterns = [
        r"topResumedActivity=.*?\{[^ ]* [^ ]* ([^\s/}]+)\/([^\s}]+)",
        r"mResumedActivity=.*?\{[^ ]* [^ ]* ([^\s/}]+)\/([^\s}]+)",
    ]
    for pattern in patterns:
        match = re.search(pattern, output)
        if match:
            return {"packageName": match.group(1), "activity": match.group(2)}
    raise ToolError("Could not determine the current foreground activity.")


def get_device_info(device_id):
    fields = {
        "model": ["shell", "getprop", "ro.product.model"],
        "manufacturer": ["shell", "getprop", "ro.product.manufacturer"],
        "androidVersion": ["shell", "getprop", "ro.build.version.release"],
        "apiLevel": ["shell", "getprop", "ro.build.version.sdk"],
        "screenSize": ["shell", "wm", "size"],
        "density": ["shell", "wm", "density"],
        "serial": ["shell", "getprop", "ro.serialno"],
        "build": ["shell", "getprop", "ro.build.display.id"],
    }

    info = {}
    for key, command in fields.items():
        info[key] = adb_text(command, device_id=device_id, timeout=10).strip()

    size_match = re.search(r"(\d+x\d+)", info["screenSize"])
    density_match = re.search(r"(\d+)", info["density"])
    info["screenSize"] = size_match.group(1) if size_match else info["screenSize"]
    info["density"] = density_match.group(1) if density_match else info["density"]
    return info


def png_dimensions(data):
    if data[:8] != b"\x89PNG\r\n\x1a\n":
        return None
    if len(data) < 24:
        return None
    width, height = struct.unpack(">II", data[16:24])
    return width, height


def detect_package_from_apk(apk_path):
    aapt = discover_build_tool("aapt")
    if aapt:
        result = run_command([aapt, "dump", "badging", apk_path], text=True, check=False, timeout=20)
        match = re.search(r"package: name='([^']+)'", result.stdout + result.stderr)
        if match:
            return match.group(1)

    apkanalyzer = discover_build_tool("apkanalyzer")
    if apkanalyzer:
        result = run_command(
            [apkanalyzer, "manifest", "application-id", apk_path],
            text=True,
            check=False,
            timeout=20,
        )
        package_name = (result.stdout or "").strip()
        if package_name:
            return package_name

    return None


def get_logs(device_id, package_name=None, level=None, lines=200, since=None):
    args = ["logcat", "-d"]
    if since:
        args.extend(["-T", since])
    else:
        args.extend(["-t", str(lines)])
    if level:
        args.append(f"*:{level.upper()}")

    output = adb_text(args, device_id=device_id, timeout=20)

    if package_name:
        pid_result = adb_result(["shell", "pidof", package_name], device_id=device_id, check=False, timeout=10)
        pids = [pid for pid in (pid_result.stdout or "").split() if pid]
        if pids:
            pid_set = set(pids)
            filtered = []
            for line in output.splitlines():
                match = re.match(r"^\S+\s+\S+\s+(\d+)\s", line)
                if match and match.group(1) in pid_set:
                    filtered.append(line)
            output = "\n".join(filtered)

    return output


def print_output(payload, as_json):
    if as_json:
        print(json.dumps(payload, indent=2))
        return

    if isinstance(payload, str):
        print(payload)
        return

    print(json.dumps(payload, indent=2))


def add_common_json(parser):
    parser.add_argument("--json", action="store_true", help="Emit structured JSON output")


def add_common_device(parser):
    parser.add_argument("--device", help="Target a specific device ID")


def cmd_device_list(args):
    devices = get_devices()
    payload = {"devices": devices, "count": len(devices)}
    if args.json:
        print_output(payload, True)
        return

    if not devices:
        print("No devices connected.")
        return

    for device in devices:
        model = f" model:{device['model']}" if device["model"] else ""
        print(f"{device['id']} [{device['state']}]{model}")


def cmd_device_info(args):
    device_id = choose_device(args.device)
    info = get_device_info(device_id)
    payload = {"deviceId": device_id, **info}
    if args.json:
        print_output(payload, True)
        return

    print(f"Device: {device_id}")
    print(f"Model: {info['manufacturer']} {info['model']}")
    print(f"Android: {info['androidVersion']} (API {info['apiLevel']})")
    print(f"Screen: {info['screenSize']} @ {info['density']}dpi")
    print(f"Build: {info['build']}")


def cmd_device_avds(args):
    result = run_command([EMULATOR_PATH, "-list-avds"], text=True, check=True, timeout=10)
    avds = [line.strip() for line in result.stdout.splitlines() if line.strip()]
    payload = {"avds": avds, "count": len(avds)}
    if args.json:
        print_output(payload, True)
        return
    if not avds:
        print("No AVDs found.")
        return
    print("\n".join(avds))


def select_started_device(current_devices, before_ids, explicit_device=None):
    ready_ids = {device["id"] for device in current_devices if device["state"] == "device"}
    if explicit_device:
        return explicit_device if explicit_device in ready_ids else None

    new_ready = sorted(ready_ids - before_ids)
    if len(new_ready) > 1:
        device_lines = "\n".join(f"- {device_id}" for device_id in new_ready)
        raise ToolError(f"Multiple new devices detected. Re-run with --device.\n{device_lines}")
    return new_ready[0] if new_ready else None


def cmd_device_start(args):
    before_ids = {device["id"] for device in get_devices()}
    subprocess.Popen(
        [EMULATOR_PATH, "-avd", args.avd_name, "-no-snapshot-load"],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        start_new_session=True,
    )
    deadline = time.time() + args.timeout / 1000.0
    while time.time() < deadline:
        try:
            current_devices = get_devices()
            device_id = select_started_device(current_devices, before_ids, explicit_device=args.device)
            if not device_id:
                time.sleep(2)
                continue
            boot = adb_text(["shell", "getprop", "sys.boot_completed"], device_id=device_id, timeout=5).strip()
            if boot == "1":
                payload = {"deviceId": device_id, "bootCompleted": True}
                print_output(payload, args.json)
                return
        except ToolError:
            pass
        time.sleep(2)
    raise ToolError(f"Emulator {args.avd_name} did not finish booting within {args.timeout}ms.")


def cmd_screenshot(args):
    device_id = choose_device(args.device)
    data = adb_bytes(["exec-out", "screencap", "-p"], device_id=device_id, timeout=20)
    out_path = args.out
    if not out_path:
        handle = tempfile.NamedTemporaryFile(prefix="android-screenshot-", suffix=".png", delete=False)
        handle.close()
        out_path = handle.name
    out_file = pathlib.Path(out_path)
    out_file.parent.mkdir(parents=True, exist_ok=True)
    out_file.write_bytes(data)

    dimensions = png_dimensions(data) or (None, None)
    payload = {
        "deviceId": device_id,
        "path": str(out_file.resolve()),
        "bytes": len(data),
        "width": dimensions[0],
        "height": dimensions[1],
    }
    if args.json:
        print_output(payload, True)
        return

    print(f"Saved screenshot to {payload['path']}")
    if payload["width"] and payload["height"]:
        print(f"Dimensions: {payload['width']}x{payload['height']}")


def load_ui_elements(device_id):
    xml = get_ui_xml(device_id)
    return xml, parse_ui_xml(xml)


def cmd_ui_dump(args):
    device_id = choose_device(args.device)
    xml, elements = load_ui_elements(device_id)
    payload = {"deviceId": device_id, "count": len(elements), "elements": elements}
    if args.json:
        print_output(payload, True)
        return

    print(f"Found {len(elements)} elements")
    for index, element in enumerate(elements):
        parts = [f"[{index}]"]
        if element["resourceId"]:
            parts.append(f"id:{element['resourceId']}")
        if element["text"]:
            parts.append(f'text:"{element["text"]}"')
        if element["contentDesc"]:
            parts.append(f'desc:"{element["contentDesc"]}"')
        parts.append(f"class:{element['className'].split('.')[-1]}")
        parts.append(f"center:({element['center']['x']},{element['center']['y']})")
        print(" ".join(parts))
    if args.raw_xml:
        print()
        print(xml)


def cmd_ui_find(args):
    device_id = choose_device(args.device)
    _, elements = load_ui_elements(device_id)
    matches = find_elements(elements, args.by, args.value)
    payload = {
        "deviceId": device_id,
        "selector": {"by": args.by, "value": args.value},
        "count": len(matches),
        "bestMatch": matches[0] if matches else None,
        "matches": matches,
    }
    if args.json:
        print_output(payload, True)
        return

    if not matches:
        print(f'No element found for {args.by}="{args.value}"')
        return

    best = matches[0]
    print(f'Found {len(matches)} match(es) for {args.by}="{args.value}"')
    print(json.dumps(best, indent=2))


def cmd_input_tap(args):
    device_id = choose_device(args.device)
    adb_text(["shell", "input", "tap", str(args.x), str(args.y)], device_id=device_id, timeout=10)
    print_output({"deviceId": device_id, "x": args.x, "y": args.y, "action": "tap"}, args.json)


def cmd_input_text(args):
    device_id = choose_device(args.device)
    escaped = escape_input_text(args.text)
    adb_text(["shell", "input", "text", escaped], device_id=device_id, timeout=10)
    print_output(
        {"deviceId": device_id, "action": "text", "text": args.text, "escaped": escaped},
        args.json,
    )


def cmd_input_key(args):
    device_id = choose_device(args.device)
    if args.code is None and args.key is None:
        raise ToolError("Provide either --key or --code.")
    code = args.code if args.code is not None else KEYCODES.get(args.key)
    if code is None:
        raise ToolError(f"Unknown key: {args.key}")
    adb_text(["shell", "input", "keyevent", str(code)], device_id=device_id, timeout=10)
    print_output({"deviceId": device_id, "action": "key", "code": code, "key": args.key}, args.json)


def cmd_input_swipe(args):
    device_id = choose_device(args.device)
    command = [
        "shell",
        "input",
        "swipe",
        str(args.x1),
        str(args.y1),
        str(args.x2),
        str(args.y2),
    ]
    if args.duration is not None:
